  <script>
    // pe mobil :hover nu functioneaza la touch - adaugam clasa 'open' la click
    if (window.matchMedia('(max-width: 599px)').matches) {
      document.querySelectorAll('.site-header nav > ul > li').forEach(function(li) {
        li.addEventListener('click', function(e) {
          var isOpen = li.classList.contains('open');
          document.querySelectorAll('.site-header nav > ul > li').forEach(function(el) {
            el.classList.remove('open');
          });
          if (!isOpen) li.classList.add('open');
          e.stopPropagation();
        });
      });
      document.addEventListener('click', function() {
        document.querySelectorAll('.site-header nav > ul > li').forEach(function(el) {
          el.classList.remove('open');
        });
      });
    }
  </script>
