<%- include('../fragmente/head', {titlu: typeof produs !== 'undefined' ? produs.nume + ' - PETHUB' : 'Produs PETHUB'}) %>
<body id="top">

<%- include('../fragmente/header') %>

<main class="page-content" style="padding: 2rem 1rem; max-width: 1100px; margin: auto;">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb" style="background: transparent; padding: 0; margin-bottom: 1.5rem;">
      <li class="breadcrumb-item"><a href="/">Acasă</a></li>
      <li class="breadcrumb-item"><a href="/produse">Produse</a></li>
      <li class="breadcrumb-item active" aria-current="page"><%= produs ? produs.nume : 'Produs' %></li>
    </ol>
  </nav>

  <% if (typeof produs !== 'undefined' && produs) { %>
    <header style="margin-bottom: 1.5rem;">
      <h1 style="margin-bottom: 0.5rem;"><%= produs.nume %></h1>
      <p style="max-width: 65rem; line-height: 1.8;"><%= produs.descriere %></p>
    </header>

    <!-- Bonus 9: Carusel Imagini Multiple -->
    <div style="margin-bottom: 2rem; max-width: 600px; border-radius: 0.75rem; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
      <div id="caruselProdus" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">
          <% if (produs.imagini_carusel && produs.imagini_carusel.length > 0) { %>
            <% produs.imagini_carusel.forEach(function(imgUrl, idx) { %>
              <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                <img src="<%= imgUrl %>" class="d-block w-100" alt="<%= produs.nume %> imagine <%= idx + 1 %>" style="height: 400px; object-fit: contain; background: #fff;">
              </div>
            <% }); %>
          <% } else { %>
            <div class="carousel-item active">
              <img src="<%= produs.imagine %>" class="d-block w-100" alt="<%= produs.nume %>" style="height: 400px; object-fit: contain; background: #fff;">
            </div>
          <% } %>
        </div>
        <% if (produs.imagini_carusel && produs.imagini_carusel.length > 1) { %>
          <button class="carousel-control-prev" type="button" data-bs-target="#caruselProdus" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true" style="background-color: rgba(0,0,0,0.5); border-radius: 50%; padding: 1.5rem;"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#caruselProdus" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true" style="background-color: rgba(0,0,0,0.5); border-radius: 50%; padding: 1.5rem;"></span>
            <span class="visually-hidden">Next</span>
          </button>
        <% } %>
      </div>
    </div>

    <section style="display: grid; gap: 1.5rem;">
      <div style="display: grid; grid-template-columns: minmax(240px, 1fr) minmax(240px, 1fr); gap: 1rem;">
        <div style="padding: 1rem; border: 1px solid #dee2e6; border-radius: 0.75rem; background: #fff9f5;">
          <h2 style="margin-top: 0;">Detalii produs</h2>
          <dl style="margin: 0;">
            <dt style="font-weight: 600;">Categorie mare</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.categorie_mare %></dd>
            <dt style="font-weight: 600;">Subcategorie</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.subcategorie %></dd>
            <dt style="font-weight: 600;">Preț</dt>
            <dd style="margin: 0 0 0.75rem;"><strong><%= Number(produs.pret).toFixed(2) %> lei</strong></dd>
            <dt style="font-weight: 600;">Stoc</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.cantitate %> buc.</dd>
            <dt style="font-weight: 600;">Culoare</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.culoare %></dd>
            <dt style="font-weight: 600;">Livrare poștă</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.livrare_posta ? 'Da' : 'Nu' %></dd>
          </dl>
        </div>

        <div style="padding: 1rem; border: 1px solid #dee2e6; border-radius: 0.75rem; background: #f8f5f1;">
          <h2 style="margin-top: 0;">Specificații esențiale</h2>
          <dl style="margin: 0;">
            <dt style="font-weight: 600;">Producător</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.producator %></dd>
            <dt style="font-weight: 600;">Țara de origine</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.tara_origine %></dd>
            <dt style="font-weight: 600;">Garanție</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.garantie %></dd>
            <dt style="font-weight: 600;">Promoție</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.promotie %></dd>
            <dt style="font-weight: 600;">Data adăugării</dt>
            <dd style="margin: 0 0 0.75rem;"><%= produs.data_adaugare %></dd>
          </dl>
        </div>
      </div>

      <div style="padding: 1rem; border: 1px solid #dee2e6; border-radius: 0.75rem; background: #ffffff;">
        <h2>Descriere completă</h2>
        <p style="margin-top: 0;"><%= produs.descriere %></p>
        <h3 style="margin-bottom: 0.5rem;">Recomandat pentru</h3>
        <p><%= produs.recomandat %></p>
        <h3 style="margin-bottom: 0.5rem;">Ingrediente / materiale</h3>
        <p><%= produs.ingrediente %></p>
        <h3 style="margin-bottom: 0.5rem;">Caracteristici principale</h3>
        <ul style="margin-top: 0; padding-left: 1.2rem;">
          <% if (Array.isArray(produs.specificatii)) { %>
            <% produs.specificatii.forEach(function(item) { %>
              <li><%= item %></li>
            <% }) %>
          <% } %>
        </ul>
      </div>
    </section>
  <% } else { %>
    <div style="padding: 2rem; border: 1px solid #dee2e6; border-radius: 0.75rem; background: #fff3f0;">
      <h2>Produs inexistent</h2>
      <p>Nu s-a găsit produsul solicitat. Reveniți la <a href="/produse">lista de produse</a>.</p>
    </div>
  <% } %>
</main>

<%- include('../fragmente/footer') %>
</body>
</html>
